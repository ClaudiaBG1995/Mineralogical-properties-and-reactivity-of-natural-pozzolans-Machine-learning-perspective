        "# BLOQUE 3: Funciones de limpieza\n",
        "def importar_datos(path_excel: str) -> pd.DataFrame:\n",
        "    \"\"\"Importa datos desde Excel.\"\"\"\n",
        "    df = pd.read_excel(path_excel, sheet_name=0)\n",
        "    print(f\"Datos importados: {df.shape[0]} registros, {df.shape[1]} columnas\")\n",
        "    return df\n",
        "\n",
        "def detectar_outliers_iqr(\n",
        "    df: pd.DataFrame,\n",
        "    columnas: List[str],\n",
        "    factor_iqr: float = 1.5\n",
        ") -> pd.Series:\n",
        "    \"\"\"Detecta outliers usando método IQR.\"\"\"\n",
        "    outlier_flags = pd.DataFrame(index=df.index)\n",
        "\n",
        "    print(\"\\nDetección de outliers usando método IQR:\")\n",
        "    print(f\"Factor IQR: {factor_iqr}\")\n",
        "\n",
        "    for col in columnas:\n",
        "        if col in df.columns:\n",
        "            Q1 = df[col].quantile(0.25)\n",
        "            Q3 = df[col].quantile(0.75)\n",
        "            IQR = Q3 - Q1\n",
        "\n",
        "            limite_inferior = Q1 - factor_iqr * IQR\n",
        "            limite_superior = Q3 + factor_iqr * IQR\n",
        "\n",
        "            outliers_col = (df[col] < limite_inferior) | (df[col] > limite_superior)\n",
        "            outlier_flags[col] = outliers_col\n",
        "\n",
        "            n_outliers = outliers_col.sum()\n",
        "\n",
        "            if n_outliers > 0:\n",
        "                print(f\"  {col}:\")\n",
        "                print(f\"    Rango normal: [{limite_inferior:.3f}, {limite_superior:.3f}]\")\n",
        "                print(f\"    Outliers: {n_outliers} ({n_outliers/len(df)*100:.1f}%)\")\n",
        "\n",
        "    is_outlier = outlier_flags.any(axis=1)\n",
        "    total_outliers = is_outlier.sum()\n",
        "    print(f\"\\nTotal registros con outliers: {total_outliers} ({total_outliers/len(df)*100:.1f}%)\")\n",
        "\n",
        "    return is_outlier\n",
        "\n",
        "def seleccionar_y_limpiar(\n",
        "    df: pd.DataFrame,\n",
        "    feature_cols: List[str],\n",
        "    target_col: str,\n",
        "    id_col: str = 'ID',\n",
        "    factor_iqr: float = 1.5\n",
        ") -> pd.DataFrame:\n",
        "    \"\"\"Selecciona features y ELIMINA registros con nulos.\"\"\"\n",
        "    columnas_a_usar = feature_cols + [target_col]\n",
        "\n",
        "    if id_col and id_col in df.columns:\n",
        "        df_sel = df[[id_col] + columnas_a_usar].copy()\n",
        "    else:\n",
        "        df_sel = df[columnas_a_usar].copy()\n",
        "        df_sel.insert(0, 'ID', range(1, len(df_sel) + 1))\n",
        "        id_col = 'ID'\n",
        "\n",
        "    print(f\"Registros iniciales: {df_sel.shape[0]}\")\n",
        "\n",
        "    nulos_mask = df_sel[columnas_a_usar].isnull()\n",
        "\n",
        "    if nulos_mask.sum().sum() > 0:\n",
        "        nulos_por_col = nulos_mask.sum()\n",
        "        filas_con_nulos = nulos_mask.any(axis=1).sum()\n",
        "\n",
        "        print(f\"\\nValores nulos detectados:\")\n",
        "        print(f\"  Filas afectadas: {filas_con_nulos}\")\n",
        "        for col, count in nulos_por_col[nulos_por_col > 0].items():\n",
        "            print(f\"    {col}: {count} nulos\")\n",
        "\n",
        "        df_sel = df_sel.dropna(subset=columnas_a_usar)\n",
        "        print(f\"\\nRegistros eliminados: {filas_con_nulos}\")\n",
        "    else:\n",
        "        print(\"\\nSin valores nulos detectados\")\n",
        "\n",
        "    df_sel['is_outlier'] = detectar_outliers_iqr(\n",
        "        df_sel[columnas_a_usar],\n",
        "        columnas_a_usar,\n",
        "        factor_iqr\n",
        "    )\n",
        "\n",
        "    df_sel['tiene_imputacion'] = False\n",
        "    df_sel['columnas_imputadas'] = ''\n",
        "\n",
        "    print(f\"\\nRegistros finales: {df_sel.shape[0]}\")\n",
        "    print(f\"Registros con outliers: {df_sel['is_outlier'].sum()}\")\n",
        "\n",
        "    cols_ordenadas = [id_col] + feature_cols + [target_col] + ['is_outlier', 'tiene_imputacion', 'columnas_imputadas']\n",
        "    df_sel = df_sel[cols_ordenadas]\n",
        "\n",
        "    return df_sel\n",
        "\n",
        "# Cargar y limpiar datos\n",
        "df_origen = importar_datos(PATH_EXCEL)\n",
        "df_limpio = seleccionar_y_limpiar(\n",
