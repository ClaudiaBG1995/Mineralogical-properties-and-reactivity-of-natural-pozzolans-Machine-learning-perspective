        "# BLOQUE 14: Repeated K-Fold CV (IMPRESIÓN SIMPLE)\n",
        "\n",
        "def validacion_robusta(modelo, X, y, nombre_modelo: str):\n",
        "    \"\"\"\n",
        "    Repeated K-Fold CV con salida resumida en una línea.\n",
        "    Configuración: 5 folds × 3 repeticiones = 15 evaluaciones.\n",
        "    \"\"\"\n",
        "    rkf = RepeatedKFold(n_splits=5, n_repeats=3, random_state=42)\n",
        "    cv_r2 = cross_val_score(modelo, X, y, scoring=\"r2\", cv=rkf, n_jobs=-1)\n",
        "\n",
        "    median_r2 = np.median(cv_r2)\n",
        "    q1 = np.percentile(cv_r2, 25)\n",
        "    q3 = np.percentile(cv_r2, 75)\n",
        "    mean_r2 = cv_r2.mean()\n",
        "    std_r2 = cv_r2.std()\n",
        "\n",
        "    print(f\"{nombre_modelo:20s} — R² median [IQR]: {median_r2:.3f} [{q1:.3f}, {q3:.3f}] | mean±std: {mean_r2:.3f}±{std_r2:.3f}\")\n",
