        "# BLOQUE 6: Comparación de estrategias (SOLO ORIGINALES vs AMBOS)\n",
        "\n",
        "def comparar_estrategias(\n",
        "    df_train: pd.DataFrame,\n",
        "    df_test: pd.DataFrame,\n",
        "    feature_cols: List[str],\n",
        "    target_col: str\n",
        ") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Compara rendimiento entrenando con:\n",
        "    1. SOLO datos originales\n",
        "    2. Datos originales + sintéticos\n",
        "\n",
        "    Evaluación SIEMPRE sobre datos originales del test.\n",
        "    \"\"\"\n",
        "\n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(\"COMPARACIÓN DE ESTRATEGIAS\")\n",
