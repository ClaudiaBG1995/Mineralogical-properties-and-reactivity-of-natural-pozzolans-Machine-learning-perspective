        "# BLOQUE 14: Repeated K-Fold CV con cálculo CORRECTO de overfitting\n",
        "\n",
        "def validacion_robusta_con_overfitting(modelo, X, y, nombre_modelo: str):\n",
        "    \"\"\"\n",
        "    Repeated K-Fold CV calculando overfitting DENTRO de cada fold.\n",
        "    Este método es más robusto que un solo hold-out.\n",
        "    \"\"\"\n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(f\"{nombre_modelo} - REPEATED K-FOLD CV (5×3)\")\n",
        "    print(f\"{'='*70}\")\n",
        "\n",
        "    rkf = RepeatedKFold(n_splits=5, n_repeats=3, random_state=42)\n",
        "\n",
        "    fold_num = 1\n",
        "    resultados_folds = []\n",
        "\n",
        "    for train_idx, val_idx in rkf.split(X):\n",
        "        if isinstance(X, np.ndarray):\n",
        "            X_train_fold = X[train_idx]\n",
        "            X_val_fold = X[val_idx]\n",
        "            y_train_fold = y.iloc[train_idx] if hasattr(y, 'iloc') else y[train_idx]\n",
        "            y_val_fold = y.iloc[val_idx] if hasattr(y, 'iloc') else y[val_idx]\n",
        "        else:\n",
        "            X_train_fold = X.iloc[train_idx]\n",
        "            X_val_fold = X.iloc[val_idx]\n",
        "            y_train_fold = y.iloc[train_idx]\n",
        "            y_val_fold = y.iloc[val_idx]\n",
        "\n",
        "        modelo.fit(X_train_fold, y_train_fold)\n",
        "\n",
        "        # Predicciones train y val\n",
        "        y_pred_train = modelo.predict(X_train_fold)\n",
        "        y_pred_val = modelo.predict(X_val_fold)\n",
        "\n",
        "        # Métricas train\n",
        "        r2_train = r2_score(y_train_fold, y_pred_train)\n",
        "        rmse_train = np.sqrt(mean_squared_error(y_train_fold, y_pred_train))\n",
        "\n",
        "        # Métricas val\n",
        "        r2_val = r2_score(y_val_fold, y_pred_val)\n",
        "        rmse_val = np.sqrt(mean_squared_error(y_val_fold, y_pred_val))\n",
        "\n",
        "        # Overfitting por fold\n",
        "        overfitting = r2_train - r2_val\n",
        "\n",
        "        resultados_folds.append({\n",
        "            'fold': fold_num,\n",
        "            'r2_train': r2_train,\n",
        "            'r2_val': r2_val,\n",
        "            'rmse_train': rmse_train,\n",
        "            'rmse_val': rmse_val,\n",
        "            'overfitting': overfitting\n",
        "        })\n",
        "\n",
        "        print(f\"Fold {fold_num:2d}/15: Train R²={r2_train:.4f}, Val R²={r2_val:.4f}, \"\n",
        "              f\"RMSE={rmse_val:.2f}, Overfit={overfitting:+.4f}\")\n",
        "        fold_num += 1\n",
        "\n",
        "    df_folds = pd.DataFrame(resultados_folds)\n",
        "\n",
        "    # Estadísticas agregadas\n",
        "    print(f\"\\n{'-'*70}\")\n",
        "    print(\"ESTADÍSTICAS AGREGADAS:\")\n",
        "    print(f\"{'-'*70}\")\n",
        "    print(f\"R² Train - Media: {df_folds['r2_train'].mean():.4f} ± {df_folds['r2_train'].std():.4f}\")\n",
        "    print(f\"R² Val - Media: {df_folds['r2_val'].mean():.4f} ± {df_folds['r2_val'].std():.4f}\")\n",
        "    print(f\"RMSE Val - Media: {df_folds['rmse_val'].mean():.3f} ± {df_folds['rmse_val'].std():.3f}\")\n",
        "\n",
        "    # OVERFITTING PROMEDIO (lo más importante)\n",
        "    overfitting_medio = df_folds['overfitting'].mean()\n",
        "    overfitting_std = df_folds['overfitting'].std()\n",
        "\n",
        "    print(f\"\\n{'-'*70}\")\n",
        "    print(\"ANÁLISIS DE OVERFITTING (basado en 15 folds):\")\n",
        "    print(f\"{'-'*70}\")\n",
        "    print(f\"Overfitting - Media: {overfitting_medio:+.4f} ± {overfitting_std:.4f}\")\n",
        "    print(f\"Overfitting - Mediana: {df_folds['overfitting'].median():+.4f}\")\n",
        "    print(f\"Overfitting - Rango: [{df_folds['overfitting'].min():+.4f}, {df_folds['overfitting'].max():+.4f}]\")\n",
        "\n",
        "    # Clasificación basada en CV (no en hold-out único)\n",
        "    if overfitting_medio < 0:\n",
        "        nivel_cv = \"⚠ UNDERFITTING - Modelo demasiado simple\"\n",
        "        simbolo = \"⚠\"\n",
        "    elif overfitting_medio < 0.05:\n",
        "        nivel_cv = \"✓ EXCELENTE - Generaliza muy bien\"\n",
        "        simbolo = \"✓\"\n",
        "    elif overfitting_medio < 0.10:\n",
        "        nivel_cv = \"✓ BUENO - Overfitting mínimo\"\n",
        "        simbolo = \"✓\"\n",
        "    elif overfitting_medio < 0.20:\n",
        "        nivel_cv = \"~ MODERADO - Overfitting aceptable\"\n",
        "        simbolo = \"~\"\n",
        "    else:\n",
        "        nivel_cv = \"✗ ALTO - Overfitting significativo\"\n",
        "        simbolo = \"✗\"\n",
        "\n",
        "    print(f\"\\n{simbolo} Nivel de Overfitting: {nivel_cv}\")\n",
        "\n",
        "    # Estabilidad\n",
        "    cv_coef_var = df_folds['r2_val'].std() / df_folds['r2_val'].mean() if df_folds['r2_val'].mean() > 0 else 0\n",
        "\n",
        "    print(f\"\\n{'-'*70}\")\n",
        "    print(\"ESTABILIDAD DEL MODELO:\")\n",
        "    print(f\"{'-'*70}\")\n",
        "    print(f\"Coeficiente de variación (CV): {cv_coef_var*100:.2f}%\")\n",
        "    if cv_coef_var < 0.10:\n",
        "        print(\"✓ MUY ESTABLE\")\n",
