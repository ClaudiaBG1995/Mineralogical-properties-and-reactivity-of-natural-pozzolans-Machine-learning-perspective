        "# BLOQUE 4: NUEVA ESTRATEGIA - Generar pares sintéticos para TODO el dataset\n",
        "\n",
        "def generar_pares_sinteticos_completos(\n",
        "    df: pd.DataFrame,\n",
        "    feature_cols: List[str],\n",
        "    target_col: str,\n",
        "    id_col: str = 'ID',\n",
        "    factor_ruido: float = 0.03,\n",
        "    random_state: int = 42\n",
        ") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Genera un par sintético para CADA registro del dataset.\n",
        "\n",
        "    NUEVA ESTRATEGIA:\n",
        "    - Calcula estadísticas del dataset COMPLETO\n",
        "    - Crea 1 par sintético por cada registro original\n",
        "    - Mantiene trazabilidad con ID_original\n",
        "\n",
        "    ANTI-LEAKAGE: La separación train-test se hace DESPUÉS,\n",
        "    manteniendo los pares juntos.\n",
        "    \"\"\"\n",
        "    np.random.seed(random_state)\n",
        "\n",
        "    columnas_numericas = feature_cols + [target_col]\n",
        "\n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(\"GENERACIÓN DE PARES SINTÉTICOS - NUEVA ESTRATEGIA\")\n",
        "    print(f\"{'='*70}\")\n",
        "    print(f\"Dataset completo: {len(df)} registros\")\n",
        "    print(f\"Factor de ruido gaussiano: {factor_ruido*100}%\")\n",
        "    print(f\"Pares a generar: 1 sintético por cada original\")\n",
        "\n",
        "    # Crear DataFrame para datos sintéticos\n",
        "    df_sintetico = df[columnas_numericas].copy()\n",
        "\n",
        "    # Aplicar ruido gaussiano basado en estadísticas del dataset completo\n",
        "    for col in columnas_numericas:\n",
        "        std_col = df[col].std()\n",
        "        noise = np.random.normal(0, std_col * factor_ruido, size=len(df))\n",
        "        df_sintetico[col] = df[col] + noise\n",
        "\n",
        "    # Agregar metadata\n",
        "    df_sintetico[id_col] = [f\"SYN_{i+1:03d}\" for i in range(len(df))]\n",
        "    df_sintetico['ID_original'] = df[id_col].values\n",
        "    df_sintetico['is_outlier'] = False\n",
        "    df_sintetico['tiene_imputacion'] = False\n",
        "    df_sintetico['columnas_imputadas'] = ''\n",
        "    df_sintetico['es_sintetico'] = True\n",
        "\n",
        "    # Agregar flag a datos originales\n",
        "    df_original = df.copy()\n",
        "    df_original['ID_original'] = df_original[id_col]\n",
        "    df_original['es_sintetico'] = False\n",
        "\n",
        "    # Combinar manteniendo estructura de pares\n",
        "    df_con_pares = pd.concat([df_original, df_sintetico], ignore_index=True)\n",
        "\n",
        "    # Ordenar por ID_original para mantener pares juntos\n",
        "    df_con_pares = df_con_pares.sort_values('ID_original').reset_index(drop=True)\n",
        "\n",
        "    print(f\"\\nResultado:\")\n",
        "    print(f\"  Registros originales: {len(df)}\")\n",
        "    print(f\"  Registros sintéticos generados: {len(df_sintetico)}\")\n",
        "    print(f\"  Total dataset con pares: {len(df_con_pares)}\")\n",
        "    print(f\"  Ratio: 1:1 (cada original tiene su par sintético)\")\n",
        "\n",
        "    return df_con_pares\n",
        "\n",
        "# Generar pares sintéticos para todo el dataset\n",
        "df_con_pares = generar_pares_sinteticos_completos(\n",
        "    df_limpio,\n",
