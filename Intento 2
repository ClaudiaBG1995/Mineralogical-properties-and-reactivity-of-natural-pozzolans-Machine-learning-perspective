        "# BLOQUE 5: Separación train-test manteniendo pares juntos\n",
        "\n",
        "def separar_manteniendo_pares(\n",
        "    df_con_pares: pd.DataFrame,\n",
        "    test_size: float = 0.20,\n",
        "    random_state: int = 42\n",
        ") -> Tuple[pd.DataFrame, pd.DataFrame]:\n",
        "    \"\"\"\n",
        "    Separa en train-test asegurando que cada par (original + sintético)\n",
        "    permanezca en el mismo grupo.\n",
        "\n",
        "    ANTI-LEAKAGE CRÍTICO:\n",
        "    - Identifica grupos únicos por ID_original\n",
        "    - Separa GRUPOS, no registros individuales\n",
        "    - Garantiza que original y sintético estén juntos\n",
        "    \"\"\"\n",
        "\n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(\"SEPARACIÓN TRAIN-TEST MANTENIENDO PARES\")\n",
        "    print(f\"{'='*70}\")\n",
        "\n",
        "    # Obtener IDs únicos (grupos de pares)\n",
        "    ids_unicos = df_con_pares['ID_original'].unique()\n",
        "\n",
        "    # Calcular información de outliers para estratificación\n",
        "    df_original_only = df_con_pares[df_con_pares['es_sintetico'] == False].copy()\n",
        "    outlier_info = df_original_only.set_index('ID_original')['is_outlier']\n",
        "\n",
        "    # Separar IDs estratificando por outliers\n",
        "    ids_train, ids_test = train_test_split(\n",
        "        ids_unicos,\n",
        "        test_size=test_size,\n",
        "        stratify=outlier_info.loc[ids_unicos],\n",
        "        random_state=random_state\n",
        "    )\n",
        "\n",
        "    # Filtrar registros por IDs (manteniendo pares completos)\n",
        "    df_train = df_con_pares[df_con_pares['ID_original'].isin(ids_train)].copy()\n",
        "    df_test = df_con_pares[df_con_pares['ID_original'].isin(ids_test)].copy()\n",
        "\n",
        "    # Estadísticas\n",
        "    n_originales_train = (~df_train['es_sintetico']).sum()\n",
        "    n_sinteticos_train = df_train['es_sintetico'].sum()\n",
        "    n_outliers_train = df_train[~df_train['es_sintetico']]['is_outlier'].sum()\n",
        "\n",
        "    n_originales_test = (~df_test['es_sintetico']).sum()\n",
        "    n_sinteticos_test = df_test['es_sintetico'].sum()\n",
        "    n_outliers_test = df_test[~df_test['es_sintetico']]['is_outlier'].sum()\n",
        "\n",
        "    print(f\"\\nTRAIN:\")\n",
        "    print(f\"  Pares completos: {len(ids_train)}\")\n",
        "    print(f\"  Registros originales: {n_originales_train}\")\n",
        "    print(f\"  Registros sintéticos: {n_sinteticos_train}\")\n",
        "    print(f\"  Total registros: {len(df_train)}\")\n",
        "    print(f\"  Outliers (originales): {n_outliers_train} ({n_outliers_train/n_originales_train*100:.1f}%)\")\n",
        "\n",
        "    print(f\"\\nTEST:\")\n",
        "    print(f\"  Pares completos: {len(ids_test)}\")\n",
        "    print(f\"  Registros originales: {n_originales_test}\")\n",
        "    print(f\"  Registros sintéticos: {n_sinteticos_test}\")\n",
        "    print(f\"  Total registros: {len(df_test)}\")\n",
        "    print(f\"  Outliers (originales): {n_outliers_test} ({n_outliers_test/n_originales_test*100:.1f}%)\")\n",
        "\n",
        "    print(f\"\\n✓ Garantía anti-leakage: Ningún par original-sintético está dividido entre train y test\")\n",
        "\n",
        "    return df_train, df_test\n",
        "\n",
        "# Realizar separación\n",
        "df_train_nueva, df_test_nueva = separar_manteniendo_pares(\n",
        "    df_con_pares,\n",
        "    test_size=0.20,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "df_train_nueva.to_excel(RUTA_TRAIN_NUEVA, index=False)\n",
        "df_test_nueva.to_excel(RUTA_TEST_NUEVA, index=False)\n",
        "\n",
        "print(f\"\\nTrain guardado: {RUTA_TRAIN_NUEVA}\")\n",
        "print(f\"Test guardado: {RUTA_TEST_NUEVA}\")\n",
        "\n"
