        "# BLOQUE 15: Gráfico Predicted vs Actual usando fold representativo (COMBINADO)\n",
        "\n",
        "def graficar_predicted_vs_actual_fold_representativo(modelo, X, y, nombre_modelo: str, usar_escalado=False):\n",
        "    \"\"\"\n",
        "    Genera gráfico Predicted vs Actual usando el FOLD MÁS REPRESENTATIVO\n",
        "    del K-Fold CV (el más cercano a la mediana de R²).\n",
        "\n",
        "    TRAIN y VALIDATION en el MISMO gráfico con colores diferentes.\n",
        "    \"\"\"\n",
        "    import matplotlib.pyplot as plt\n",
        "\n",
        "    print(f\"\\n{'='*70}\")\n",
        "    print(f\"{nombre_modelo} - SELECCIÓN DE FOLD REPRESENTATIVO\")\n",
        "    print(f\"{'='*70}\")\n",
        "\n",
        "    rkf = RepeatedKFold(n_splits=5, n_repeats=3, random_state=42)\n",
        "\n",
        "    # Evaluar todos los folds\n",
        "    resultados_folds = []\n",
        "\n",
        "    for fold_num, (train_idx, val_idx) in enumerate(rkf.split(X), 1):\n",
        "        if isinstance(X, np.ndarray):\n",
        "            X_train_fold = X[train_idx]\n",
        "            X_val_fold = X[val_idx]\n",
        "            y_train_fold = y.iloc[train_idx] if hasattr(y, 'iloc') else y[train_idx]\n",
        "            y_val_fold = y.iloc[val_idx] if hasattr(y, 'iloc') else y[val_idx]\n",
        "        else:\n",
        "            X_train_fold = X.iloc[train_idx]\n",
        "            X_val_fold = X.iloc[val_idx]\n",
        "            y_train_fold = y.iloc[train_idx]\n",
        "            y_val_fold = y.iloc[val_idx]\n",
        "\n",
        "        modelo.fit(X_train_fold, y_train_fold)\n",
        "\n",
        "        y_pred_train = modelo.predict(X_train_fold)\n",
        "        y_pred_val = modelo.predict(X_val_fold)\n",
        "\n",
        "        r2_train = r2_score(y_train_fold, y_pred_train)\n",
        "        r2_val = r2_score(y_val_fold, y_pred_val)\n",
        "\n",
        "        resultados_folds.append({\n",
        "            'fold': fold_num,\n",
        "            'r2_train': r2_train,\n",
        "            'r2_val': r2_val,\n",
        "            'train_idx': train_idx,\n",
        "            'val_idx': val_idx,\n",
        "            'y_train': y_train_fold,\n",
        "            'y_val': y_val_fold,\n",
        "            'y_pred_train': y_pred_train,\n",
        "            'y_pred_val': y_pred_val\n",
        "        })\n",
        "\n",
        "    df_folds = pd.DataFrame(resultados_folds)\n",
        "\n",
        "    # Seleccionar fold más cercano a la mediana\n",
        "    mediana_r2_val = df_folds['r2_val'].median()\n",
        "    df_folds['dist_mediana'] = abs(df_folds['r2_val'] - mediana_r2_val)\n",
        "    fold_representativo_idx = df_folds['dist_mediana'].idxmin()\n",
        "    fold_rep = resultados_folds[fold_representativo_idx]\n",
        "\n",
        "    print(f\"\\nEstadísticas de R² validación en 15 folds:\")\n",
        "    print(f\"  Media: {df_folds['r2_val'].mean():.4f}\")\n",
        "    print(f\"  Mediana: {mediana_r2_val:.4f}\")\n",
        "    print(f\"  Rango: [{df_folds['r2_val'].min():.4f}, {df_folds['r2_val'].max():.4f}]\")\n",
        "\n",
        "    print(f\"\\n✓ Fold seleccionado: {fold_rep['fold']}/15\")\n",
        "    print(f\"  Train R²: {fold_rep['r2_train']:.4f}\")\n",
        "    print(f\"  Val R²: {fold_rep['r2_val']:.4f} (más cercano a mediana {mediana_r2_val:.4f})\")\n",
        "    print(f\"  Overfitting: {fold_rep['r2_train'] - fold_rep['r2_val']:+.4f}\")\n",
        "\n",
        "    # GRÁFICO COMBINADO (Train + Validation en el mismo plot)\n",
        "    fig, ax = plt.subplots(1, 1, figsize=(10, 8))\n",
        "\n",
        "    # Extraer datos\n",
        "    y_train_vals = fold_rep['y_train']\n",
        "    y_pred_train_vals = fold_rep['y_pred_train']\n",
        "    y_val_vals = fold_rep['y_val']\n",
        "    y_pred_val_vals = fold_rep['y_pred_val']\n",
        "\n",
        "    # Scatter TRAIN (azul)\n",
        "    ax.scatter(y_train_vals, y_pred_train_vals,\n",
        "               alpha=0.6, s=80, color='#1f77b4',\n",
        "               edgecolors='k', linewidth=0.6,\n",
        "               label=f'Train (R²={fold_rep[\"r2_train\"]:.3f})',\n",
        "               marker='o')\n",
        "\n",
        "    # Scatter VALIDATION (verde)\n",
        "    ax.scatter(y_val_vals, y_pred_val_vals,\n",
        "               alpha=0.7, s=100, color='#2ca02c',\n",
        "               edgecolors='k', linewidth=0.8,\n",
        "               label=f'Validation (R²={fold_rep[\"r2_val\"]:.3f})',\n",
        "               marker='s')\n",
        "\n",
        "    # Línea perfecta (roja)\n",
        "    min_val = min(y_train_vals.min(), y_val_vals.min(),\n",
        "                  y_pred_train_vals.min(), y_pred_val_vals.min())\n",
        "    max_val = max(y_train_vals.max(), y_val_vals.max(),\n",
        "                  y_pred_train_vals.max(), y_pred_val_vals.max())\n",
        "\n",
        "    ax.plot([min_val, max_val], [min_val, max_val],\n",
        "            'r--', lw=2.5, alpha=0.8, label='Predicción perfecta')\n",
        "\n",
        "    # Etiquetas y título\n",
        "    ax.set_xlabel('Actual Values', fontsize=13, fontweight='bold')\n",
        "    ax.set_ylabel('Predicted Values', fontsize=13, fontweight='bold')\n",
        "\n",
        "    overfitting = fold_rep['r2_train'] - fold_rep['r2_val']\n",
        "    ax.set_title(f'{nombre_modelo}\\nFold {fold_rep[\"fold\"]}/15 | Overfitting = {overfitting:+.4f}',\n",
        "                 fontsize=14, fontweight='bold', pad=15)\n",
        "\n",
        "    # Leyenda y grid\n",
        "    ax.legend(loc='upper left', fontsize=11, framealpha=0.95)\n",
        "    ax.grid(True, alpha=0.3, linestyle='--')\n",
        "\n",
        "    # Ajustar límites para dar espacio visual\n",
        "    padding = (max_val - min_val) * 0.05\n",
        "    ax.set_xlim(min_val - padding, max_val + padding)\n",
        "    ax.set_ylim(min_val - padding, max_val + padding)\n",
        "\n",
        "    # Hacer el gráfico cuadrado\n",
        "    ax.set_aspect('equal', adjustable='box')\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    return fold_rep, df_folds\n",
        "\n",
        "\n",
        "# Generar gráficos para todos los modelos\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"GRÁFICOS PREDICTED vs ACTUAL - USANDO FOLDS REPRESENTATIVOS\")\n",
        "print(\"TRAIN (azul círculos) + VALIDATION (verde cuadrados)\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "fold_rf, stats_rf = graficar_predicted_vs_actual_fold_representativo(\n",
        "    rf_model, X_train, y_train, \"Random Forest\", usar_escalado=False\n",
        ")\n",
        "\n",
        "fold_svm, stats_svm = graficar_predicted_vs_actual_fold_representativo(\n",
        "    svm_model, X_train_scaled, y_train, \"SVM\", usar_escalado=True\n",
        ")\n",
        "\n",
        "fold_mlp, stats_mlp = graficar_predicted_vs_actual_fold_representativo(\n",
        "    mlp_model, X_train_scaled, y_train, \"MLP\", usar_escalado=True\n",
        ")\n",
        "\n",
        "fold_lr, stats_lr = graficar_predicted_vs_actual_fold_representativo(\n",
        "    modelos_lr['Linear'], X_train_scaled, y_train, \"Linear Regression\", usar_escalado=True\n",
        ")\n",
        "\n"
